# Swarm Prime Directive — Environment Variables

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — override defaults
SWARM_LOG_LEVEL=INFO
SWARM_CYCLES=1
SWARM_FOCUS=general capability improvement

# AWS (for ECS deployment)
AWS_REGION=us-east-1
ANTHROPIC_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:anthropic-api-key
